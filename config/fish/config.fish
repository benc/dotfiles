# Required background music for this config file:
#
# https://soundcloud.com/mr-scruff/shanty-town
#
# After you've done that, install oh-my-fish:
#
# https://github.com/bpinto/oh-my-fish

set fish_path $HOME/.oh-my-fish
set fish_custom $HOME/.dotfiles/fish
set fish_theme robbyrussell
set fish_plugins brew bundler rails rbenv sublime node

. $fish_path/oh-my-fish.fish

source_script $HOME/.nvm/nvm.sh

