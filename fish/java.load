# Generic java stuff
# ==================
set -x JAVA_OPTS "-Djava.awt.headless=true -Dfile.encoding=UTF-8"

switch (uname)
    case Linux
    	echo Hi, Tux! No JAVA_HOME set for you, you should set me in java.fish
    case Darwin
    	set -x JAVA_HOME (/usr/libexec/java_home -v 1.7)
    case '*'
        echo Hi, stranger! No JAVA_HOME set for you, you should set me in java.fish
end