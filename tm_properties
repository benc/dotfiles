TM_GIT = "/usr/local/bin/git"
TM_HG = "/usr/local/bin/hg"
TM_RUBY = "/Users/benc/.rbenv/shims/ruby"
TM_FULLNAME = "Ben Cochez"

# Default editing configuration
softWrap = false
softTabs = true
tabSize = 2
encoding = UTF-8
wrapColumn = 160
showWrapColumn = true

excludeFiles = "*.{so,pyc,o,scssc}"
excludeDirectories = "build,dist,tmp,log,gems,vendor"

followSymbolicLinks = true

# File type specific configuration
[ text ]
showInvisibles = true
spellChecking = true

[ *.{icns,ico,jpg,jpeg,m4v,nib,pdf,png,psd,pyc,rtf,tif,tiff,xib} ]
binary = true

[ source ]
softTabs = true
tabSize = 2

[ source.python ]
softTabs = true
tabSize = 4

[ "{README,INSTALL,LICENSE,TODO}" ]
fileType = "text.plain"

[ attr.file.unknown-type ]
fileType = "text.plain"