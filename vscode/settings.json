// Place your settings in this file to overwrite the default settings
{
    "docker.showExplorer": false,
    "editor.fontFamily": "Hasklig",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "editor.renderIndentGuides": true,
    "editor.minimap.enabled": true,
    "files.associations": {
        "Capfile": "ruby",
        "Vagrantfile": "ruby"
    },
    "files.autoSave": "onFocusChange",
    "files.trimTrailingWhitespace": true,
    "java.errors.incompleteClasspath.severity": "ignore",
    "java.debug.settings.enableHotCodeReplace": true,
    "java.autobuild.enabled": true,
    "javascript.implicitProjectConfig.checkJs": true,
    "remote.port": 52689,
    "remote.onstartup": true,
    "remote.dontShowPortAlreadyInUseError": true,
    "terminal.external.osxExec": "iTerm.app",
    "window.nativeTabs": true,
    "workbench.editor.showTabs": false,
    "workbench.iconTheme": "material-icon-theme",
    "extensions.ignoreRecommendations": false,
    "typescript.experimental.syntaxFolding": true,
    "terminal.integrated.shell.osx": "/usr/local/bin/zsh",
    "gitlens.keymap": "chorded",
    "gitlens.advanced.messages": {
        "suppressShowKeyBindingsNotice": true
    },
    "gitlens.historyExplorer.enabled": false,
    "java.jdt.ls.vmargs": "-noverify -Xmx1G -XX:+UseG1GC -XX:+UseStringDeduplication -javaagent:\"/Users/benc/.vscode/extensions/gabrielbb.vscode-lombok-0.9.6/server/lombok.jar\" -Xbootclasspath/a:\"/Users/benc/.vscode/extensions/gabrielbb.vscode-lombok-0.9.6/server/lombok.jar\"",
    "npm.enableScriptExplorer": true,
    "breadcrumbs.enabled": true
}